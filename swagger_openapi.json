{
  "openapi": "3.0.3",
  "info": {
    "title": "PHARMAKON API",
    "description": "API REST du système de gestion pharmaceutique B2B PHARMAKON. Base URL: /api/v1. Authentification: Bearer JWT.",
    "version": "1.0.0",
    "contact": { "name": "Équipe PHARMAKON" }
  },
  "servers": [
    { "url": "/api/v1", "description": "Production" }
  ],
  "security": [{ "bearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "code": { "type": "string", "example": "FORBIDDEN" },
          "message": { "type": "string" }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "array", "items": {} },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "pages": { "type": "integer" },
          "limit": { "type": "integer" }
        }
      },
      "EFacture": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "fournisseur_id": { "type": "string", "format": "uuid" },
          "pharmacie_id": { "type": "string", "format": "uuid", "nullable": true },
          "numero": { "type": "string", "example": "EF-2026-00042" },
          "qr_code": { "type": "string", "format": "uuid" },
          "statut": {
            "type": "string",
            "enum": ["CREEE","ENVOYEE","IMPORTEE","VALIDEE","PARTIELLEMENT_ACCEPTEE","REJETEE","PAYEE","DEMANDE_MODIFICATION"]
          },
          "montant_ht": { "type": "number", "format": "decimal" },
          "montant_ttc": { "type": "number", "format": "decimal" },
          "montant_paye": { "type": "number", "format": "decimal", "nullable": true },
          "date_envoi": { "type": "string", "format": "date-time", "nullable": true },
          "date_echeance": { "type": "string", "format": "date-time", "nullable": true },
          "notes": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "DetailEFacture": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "produit_nom": { "type": "string" },
          "dci": { "type": "string", "nullable": true },
          "dosage": { "type": "string", "nullable": true },
          "forme": { "type": "string", "nullable": true },
          "num_enr_cnas": { "type": "string", "nullable": true },
          "quantite": { "type": "integer" },
          "prix_achat_ht": { "type": "number" },
          "prix_vente_ppa": { "type": "number" },
          "date_peremption": { "type": "string", "format": "date-time", "nullable": true },
          "numero_lot": { "type": "string", "nullable": true },
          "tva": { "type": "number", "nullable": true },
          "ug": { "type": "integer", "default": 0 },
          "shp": { "type": "number", "nullable": true },
          "is_para": { "type": "boolean" }
        }
      },
      "BonLivraison": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "efacture_id": { "type": "string", "format": "uuid" },
          "numero": { "type": "string", "example": "BL-2026-00017" },
          "type": { "type": "string", "enum": ["BL", "BR"] },
          "statut": { "type": "string", "enum": ["EN_COURS","COMPLETE","PARTIEL"] },
          "date_livraison": { "type": "string", "format": "date-time", "nullable": true },
          "notes": { "type": "string", "nullable": true },
          "lignes": { "type": "array", "items": { "$ref": "#/components/schemas/LigneBL" } }
        }
      },
      "LigneBL": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "detail_ef_id": { "type": "string", "format": "uuid" },
          "qte_commandee": { "type": "integer" },
          "qte_livree": { "type": "integer" },
          "qte_acceptee": { "type": "integer" }
        }
      },
      "FactureAchat": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "pharmacie_id": { "type": "string", "format": "uuid" },
          "fournisseur_id": { "type": "string", "format": "uuid", "nullable": true },
          "efacture_id": { "type": "string", "format": "uuid", "nullable": true },
          "numero_interne": { "type": "integer" },
          "numero_fournisseur": { "type": "string", "nullable": true },
          "numero_bl": { "type": "string", "nullable": true },
          "type_piece": { "type": "string", "enum": ["FACTURE","BON_LIVRAISON","AVOIR"] },
          "statut": { "type": "string", "enum": ["BROUILLON","VALIDE","AVOIR","ANNULE"] },
          "montant_ht": { "type": "number" },
          "montant_ttc": { "type": "number" },
          "montant_theorique": { "type": "number" },
          "montant_reel": { "type": "number", "nullable": true },
          "difference": { "type": "number", "nullable": true }
        }
      },
      "Vente": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "caisse_id": { "type": "string", "format": "uuid", "nullable": true },
          "statut": { "type": "string", "enum": ["BROUILLON","VALIDEE","ANNULEE"] },
          "type_vente": { "type": "string", "enum": ["LIBRE","CHIFA"] },
          "montant_total": { "type": "number" },
          "montant_net": { "type": "number" },
          "date_vente": { "type": "string", "format": "date-time" }
        }
      },
      "StockLot": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "produit_id": { "type": "string", "format": "uuid" },
          "numero_lot": { "type": "string", "nullable": true },
          "date_peremption": { "type": "string", "format": "date-time" },
          "quantite_initiale": { "type": "integer" },
          "quantite_disponible": { "type": "integer" },
          "prix_achat_ht": { "type": "number" },
          "prix_vente_ppa": { "type": "number" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "type": { "type": "string" },
          "titre": { "type": "string" },
          "message": { "type": "string" },
          "niveau": { "type": "string", "enum": ["INFO","WARNING","CRITICAL"] },
          "lue": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CatalogueItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "nom_produit": { "type": "string" },
          "dci": { "type": "string" },
          "forme": { "type": "string" },
          "dosage": { "type": "string" },
          "conditionnement": { "type": "string" },
          "num_enregistrement": { "type": "string", "nullable": true },
          "type_produit": { "type": "string", "enum": ["MEDICAMENT","PARA","COSMETIQUE"] },
          "ppa": { "type": "number" },
          "prix_achat": { "type": "number" },
          "marge_suggeree": { "type": "number" },
          "disponible": { "type": "boolean" }
        }
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Connexion utilisateur",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["email","password"],
            "properties": { "email": { "type": "string", "format": "email" }, "password": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Succès", "content": { "application/json": { "schema": { "type": "object",
            "properties": { "success": { "type": "boolean" }, "access_token": { "type": "string" }, "refresh_token": { "type": "string" },
              "user": { "type": "object", "properties": { "id": { "type": "string" }, "role": { "type": "string" }, "pharmacie_id": { "type": "string", "nullable": true } } } } } } } },
          "401": { "description": "Credentials invalides", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Renouveler l'access token",
        "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["refresh_token"],
          "properties": { "refresh_token": { "type": "string" } } } } } },
        "responses": {
          "200": { "description": "Nouveau token" },
          "401": { "description": "Token révoqué ou expiré" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Déconnexion (révocation refresh token)",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object",
          "properties": { "refresh_token": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Token révoqué" } }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Authentification"],
        "summary": "Profil utilisateur courant",
        "responses": { "200": { "description": "Profil utilisateur" } }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Créer un caissier ou manager (PROPRIETAIRE uniquement)",
        "responses": { "201": { "description": "Utilisateur créé" }, "403": { "description": "Accès refusé" } }
      }
    },
    "/auth/register-fournisseur": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Inscription publique fournisseur/laboratoire",
        "security": [],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "type": "object",
          "properties": { "nom": { "type": "string" }, "email": { "type": "string" }, "password": { "type": "string" },
            "type": { "type": "string", "enum": ["FOURNISSEUR","LABORATOIRE"] }, "registre_commerce": { "type": "string", "format": "binary" } } } } } },
        "responses": { "201": { "description": "Demande soumise, en attente validation admin" } }
      }
    },
    "/efactures": {
      "get": {
        "tags": ["E-Facture"],
        "summary": "Liste des E-Factures (scopée par rôle: fournisseur voit les siennes, pharmacie voit les reçues)",
        "parameters": [
          { "name": "statut", "in": "query", "schema": { "type": "string" } },
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "date_debut", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "date_fin", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": { "200": { "description": "Liste paginée", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } } }
      },
      "post": {
        "tags": ["E-Facture"],
        "summary": "Créer une E-Facture (brouillon) — FOURNISSEUR/LABORATOIRE",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object",
          "required": ["lignes"],
          "properties": {
            "pharmacie_id": { "type": "string", "format": "uuid", "nullable": true },
            "notes": { "type": "string" },
            "date_echeance": { "type": "string", "format": "date" },
            "lignes": { "type": "array", "minItems": 1, "items": {
              "type": "object", "required": ["produit_nom","quantite","prix_achat_ht","prix_vente_ppa"],
              "properties": {
                "produit_nom": { "type": "string" },
                "dci": { "type": "string" },
                "dosage": { "type": "string" },
                "num_enr_cnas": { "type": "string" },
                "quantite": { "type": "integer", "minimum": 1 },
                "prix_achat_ht": { "type": "number" },
                "prix_vente_ppa": { "type": "number" },
                "numero_lot": { "type": "string" },
                "date_peremption": { "type": "string", "format": "date" },
                "tva": { "type": "number" },
                "ug": { "type": "integer", "default": 0 },
                "shp": { "type": "number" },
                "is_para": { "type": "boolean", "default": false }
              }
            }}
          }
        } } } },
        "responses": { "201": { "description": "E-Facture créée", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EFacture" } } } } }
      }
    },
    "/efactures/{id}": {
      "get": {
        "tags": ["E-Facture"],
        "summary": "Détail complet d'une E-Facture (lignes, BLs, progression)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "EFacture avec lignes, BLs et payment info" } }
      }
    },
    "/efactures/{id}/send": {
      "post": {
        "tags": ["E-Facture"],
        "summary": "Envoyer l'E-Facture (CREEE → ENVOYEE) — FOURNISSEUR",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Statut ENVOYEE, notification pharmacie déclenchée" } }
      }
    },
    "/efactures/{id}/draft": {
      "delete": {
        "tags": ["E-Facture"],
        "summary": "Supprimer le brouillon (statut CREEE uniquement) — FOURNISSEUR",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Brouillon supprimé" }, "400": { "description": "Impossible: facture non en brouillon" } }
      }
    },
    "/efactures/{id}/statut": {
      "patch": {
        "tags": ["E-Facture"],
        "summary": "Mettre à jour le statut (pharmacie) — VALIDEE / PARTIELLEMENT_ACCEPTEE / REJETEE / PAYEE",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["statut"],
          "properties": {
            "statut": { "type": "string", "enum": ["VALIDEE","PARTIELLEMENT_ACCEPTEE","REJETEE","PAYEE"] },
            "notes": { "type": "string", "description": "Obligatoire si REJETEE" }
          }
        } } } },
        "responses": { "200": { "description": "Statut mis à jour, notification fournisseur déclenchée" } }
      }
    },
    "/efactures/{id}/demande-modification": {
      "post": {
        "tags": ["E-Facture"],
        "summary": "Pharmacie demande une modification — IMPORTEE → DEMANDE_MODIFICATION",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["notes"],
          "properties": { "notes": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Demande envoyée, notification fournisseur" } }
      }
    },
    "/efactures/{id}/repondre-modification": {
      "post": {
        "tags": ["E-Facture"],
        "summary": "Fournisseur répond à la demande de modification — FOURNISSEUR",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object",
          "properties": { "notes": { "type": "string" }, "lignes": { "type": "array", "items": { "$ref": "#/components/schemas/DetailEFacture" } } } } } } },
        "responses": { "200": { "description": "Réponse enregistrée, statut retour IMPORTEE" } }
      }
    },
    "/efactures/{id}/validate-stock": {
      "post": {
        "tags": ["E-Facture"],
        "summary": "Valider l'E-Facture et créer les lots de stock directement — Pharmacie",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Stock créé", "content": { "application/json": { "schema": { "type": "object",
          "properties": { "stock_created": { "type": "integer" }, "unmatched": { "type": "integer" } } } } } } }
      }
    },
    "/efactures/{id}/mark-paid": {
      "post": {
        "tags": ["E-Facture"],
        "summary": "Marquer comme payée — FOURNISSEUR",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object",
          "properties": { "montant_paye": { "type": "number" } } } } } },
        "responses": { "200": { "description": "PAYEE, montant_reste calculé" } }
      }
    },
    "/efactures/qr/{qr_code}": {
      "get": {
        "tags": ["E-Facture"],
        "summary": "Import E-Facture par QR code UUID — Pharmacie",
        "security": [],
        "parameters": [{ "name": "qr_code", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Données E-Facture pré-remplies pour formulaire achat" } }
      }
    },
    "/efactures/import/{code}": {
      "get": {
        "tags": ["E-Facture"],
        "summary": "Import E-Facture par code court (8 caractères) — Pharmacie",
        "parameters": [{ "name": "code", "in": "path", "required": true, "schema": { "type": "string", "minLength": 8, "maxLength": 8 } }],
        "responses": { "200": { "description": "Données E-Facture" } }
      }
    },
    "/efactures/recu": {
      "get": {
        "tags": ["E-Facture"],
        "summary": "Liste des E-Factures reçues — Pharmacie (PROPRIETAIRE/MANAGER)",
        "responses": { "200": { "description": "E-Factures reçues paginées" } }
      }
    },
    "/efactures/{id}/bl": {
      "post": {
        "tags": ["E-Facture"],
        "summary": "Créer un Bon de Livraison (BL) — FOURNISSEUR",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["lignes"],
          "properties": {
            "date_livraison": { "type": "string", "format": "date" },
            "notes": { "type": "string" },
            "lignes": { "type": "array", "items": { "type": "object", "required": ["detail_ef_id","qte_livree"],
              "properties": { "detail_ef_id": { "type": "string", "format": "uuid" }, "qte_livree": { "type": "integer" } } } }
          }
        } } } },
        "responses": { "201": { "description": "BL créé, statut EF recalculé" } }
      }
    },
    "/efactures/{id}/bl/{bl_id}": {
      "patch": {
        "tags": ["E-Facture"],
        "summary": "Mettre à jour un BL (statut + quantités) — FOURNISSEUR",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "bl_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "BL mis à jour" } }
      }
    },
    "/efactures/{id}/bl/{bl_id}/accept-pharmacy": {
      "patch": {
        "tags": ["E-Facture"],
        "summary": "Pharmacie accepte un BL fournisseur et crée les lots de stock — Pharmacie",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "bl_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object",
          "properties": { "lignes": { "type": "array", "items": { "type": "object",
            "properties": { "ligne_bl_id": { "type": "string", "format": "uuid" }, "qte_acceptee": { "type": "integer" } } } } } } } } },
        "responses": { "200": { "description": "BL accepté, StockLots créés" } }
      }
    },
    "/efactures/{id}/br-pharmacy": {
      "post": {
        "tags": ["E-Facture"],
        "summary": "Pharmacie crée un Bon de Réception (BR) et met à jour le stock immédiatement",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["lignes_recues"],
          "properties": { "notes": { "type": "string" },
            "lignes_recues": { "type": "array", "items": { "type": "object", "required": ["detail_ef_id","qte_recue"],
              "properties": { "detail_ef_id": { "type": "string", "format": "uuid" }, "qte_recue": { "type": "integer" } } } }
          }
        } } } },
        "responses": { "201": { "description": "BR créé, stock mis à jour", "content": { "application/json": { "schema": { "type": "object",
          "properties": { "br_numero": { "type": "string" }, "stock_created": { "type": "integer" }, "unmatched": { "type": "integer" } } } } } } }
      }
    },
    "/achats": {
      "get": {
        "tags": ["Achats"],
        "summary": "Liste des factures d'achat — ADMIN/PROPRIETAIRE/MANAGER",
        "parameters": [
          { "name": "statut", "in": "query", "schema": { "type": "string", "enum": ["BROUILLON","VALIDE","AVOIR","ANNULE"] } },
          { "name": "fournisseur_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "type_piece", "in": "query", "schema": { "type": "string", "enum": ["FACTURE","BON_LIVRAISON","AVOIR"] } },
          { "name": "date_debut", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "date_fin", "in": "query", "schema": { "type": "string", "format": "date" } },
